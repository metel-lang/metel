// ? with mismatched error types and no From impl must fail with T0007.
// METEL-80 routes ? through From-based coercion; when no From impl exists,
// the coercion is invalid and the typechecker emits T0007 (invalid cast).
// From coercion for arbitrary type pairs is deferred to #13.

fun inner() -> Result<Int, String> {
    Result::Ok { value: 42 }
}

fun outer() -> Result<Int, Int> {
    let x = inner()?; // ERROR[T0007]
    Result::Ok { value: x }
}

fun main() {}
