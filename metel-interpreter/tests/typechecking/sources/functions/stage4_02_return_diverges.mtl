// Stage 4: blocks whose only exit is `return` have type Never,
// which unifies with any expected return type.

// Single return — no tail expression
fun double(x: i64) -> i64 {
    return x * 2;
}

// Multiple return paths — no tail expression
fun sign(n: i64) -> String {
    if (n > 0) {
        return "positive";
    }
    if (n < 0) {
        return "negative";
    }
    return "zero";
}

// Early return + tail expression
fun abs_val(x: i64) -> i64 {
    if (x < 0) {
        return 0 - x;
    }
    x
}

// Void function with explicit return
fun maybe_skip(flag: boolean) -> boolean {
    if (flag) {
        return false;
    }
    true
}
