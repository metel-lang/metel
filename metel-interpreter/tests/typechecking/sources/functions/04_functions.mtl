// Test: function declaration and call type inference
//
// Functions with fully annotated parameters and return types. The typechecker
// must:
//   1. Register the function's type as (param_types...) -> return_type
//   2. Infer the body and unify it against the declared return type
//   3. At each call site, unify the argument types with the parameter types
//      and use the return type as the call expression's type
//
// Expected inferred types:
//   add(i64, i64) -> i64
//   negate(Bool) -> Bool
//   to_string(i64) -> String  (uses a built-in)
//   a : i64    (call to add)
//   b : Bool   (call to negate)
//
// The body of each function is also type-checked:
//   add body:    x + y  infers i64 — must unify with declared return i64 ✓
//   negate body: !b     infers Bool — must unify with declared return Bool ✓

fun add(x: i64, y: i64) -> i64 {
    x + y
}

fun negate(b: Bool) -> Bool {
    !b
}

let a = add(10, 32);
let b = negate(false);
