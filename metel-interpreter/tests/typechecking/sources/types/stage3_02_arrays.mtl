// Stage 3: array construction and indexing
//
// All elements must unify to a common type. The result is Array(T).
// Indexing requires an i64 index and produces the element type T.
// Empty arrays require a type annotation.

fun first(xs: i64[]) -> i64 {
    xs[0]
}

let nums: i64[] = [1, 2, 3];
let bools: Bool[] = [true, false, true];
let empty: i64[] = [];
let elem: i64 = nums[0];
let also: i64 = first(nums);
