// Stage 6: type casts (v0.1: identity casts and i64 as f64 widening only).

// Identity casts
let i: i64   = 42;
let i2: i64  = i as i64;

let g: f64 = 3.14;
let f2: f64 = g as f64;

// Widening cast: i64 as f64
let as_float: f64 = 7 as f64;

// Cast in arithmetic context
let area: f64 = g as f64 * 5.0 * 5.0;
