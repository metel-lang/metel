// Stage 5: struct instantiation, field access, methods, and field assignment.

struct Point {
    x: f64,
    y: f64,
}

impl Point {
    fun sum(self) -> f64 {
        self.x + self.y
    }

    fun translate(self, dx: f64, dy: f64) -> Point {
        Point { x: self.x + dx, y: self.y + dy }
    }

    fun scale(&mut self, factor: f64) {
        self.x = self.x * factor;
        self.y = self.y * factor;
    }
}

// Struct instantiation
let p = Point { x: 1.0, y: 2.0 };

// Field access
let x: f64 = p.x;

// Method call with no extra args
let s: f64 = p.sum();

// Method call with args, result is a struct
let q = p.translate(3.0, 4.0);
let qs: f64 = q.sum();

// Two-struct method
struct Counter {
    value: i64,
}

impl Counter {
    fun get(self) -> i64 {
        self.value
    }

    fun add(self, other: Counter) -> i64 {
        self.value + other.value
    }

    fun reset(&mut self) {
        self.value = 0;
    }
}

let c = Counter { value: 5 };
let v: i64 = c.get();
let total: i64 = c.add(Counter { value: 10 });
