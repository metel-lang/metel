// Stage 5: `Self` should resolve in ordinary struct and enum method signatures.

struct Point {
    x: i64,
}

impl Point {
    fun clone(self) -> Self {
        self
    }

    fun same_as(self, other: Self) -> boolean {
        self.x == other.x
    }
}

enum Token {
    i64 { value: i64 },
}

impl Token {
    fun identity(self) -> Self {
        self
    }
}

let p = Point { x: 1 };
let q: Point = p.clone();
let same: boolean = p.same_as(q);

let token = Token::i64 { value: 7 };
let token_copy: Token = token.identity();
