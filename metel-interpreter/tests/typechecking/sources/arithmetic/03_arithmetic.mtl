// Test: arithmetic and comparison operator type inference
//
// Arithmetic operators constrain both operands to be the same numeric type
// and produce that same type as their result.
// Comparison operators constrain both operands to be the same type and always
// produce boolean.
// Logical operators require boolean operands and produce boolean.
//
// Expected inferred types:
//   sum      : i64   (i64 + i64 -> i64)
//   product  : i64   (i64 * i64 -> i64)
//   diff     : i64   (i64 - i64 -> i64)
//   quotient : i64   (i64 / i64 -> i64)
//   fsum     : f64 (f64 + f64 -> f64)
//   eq_check : boolean  (i64 == i64 -> boolean)
//   lt_check : boolean  (i64 < i64 -> boolean)
//   and_expr : boolean  (boolean && boolean -> boolean)
//   or_expr  : boolean  (boolean || boolean -> boolean)
//   neg_int  : i64   (-i64 -> i64)
//   neg_bool : boolean  (!boolean -> boolean)

let sum      = 1 + 2;
let product  = 3 * 4;
let diff     = 10 - 3;
let quotient = 8 / 2;
let fsum     = 1.5 + 2.5;
let eq_check = 1 == 1;
let lt_check = 3 < 5;
let and_expr = true && false;
let or_expr  = true || false;
let neg_int  = -42;
let neg_bool = !true;
