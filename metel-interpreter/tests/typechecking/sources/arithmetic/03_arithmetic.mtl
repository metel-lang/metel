// Test: arithmetic and comparison operator type inference
//
// Arithmetic operators constrain both operands to be the same numeric type
// and produce that same type as their result.
// Comparison operators constrain both operands to be the same type and always
// produce Bool.
// Logical operators require Bool operands and produce Bool.
//
// Expected inferred types:
//   sum      : i64   (i64 + i64 -> i64)
//   product  : i64   (i64 * i64 -> i64)
//   diff     : i64   (i64 - i64 -> i64)
//   quotient : i64   (i64 / i64 -> i64)
//   fsum     : f64 (f64 + f64 -> f64)
//   eq_check : Bool  (i64 == i64 -> Bool)
//   lt_check : Bool  (i64 < i64 -> Bool)
//   and_expr : Bool  (Bool && Bool -> Bool)
//   or_expr  : Bool  (Bool || Bool -> Bool)
//   neg_int  : i64   (-i64 -> i64)
//   neg_bool : Bool  (!Bool -> Bool)

let sum      = 1 + 2;
let product  = 3 * 4;
let diff     = 10 - 3;
let quotient = 8 / 2;
let fsum     = 1.5 + 2.5;
let eq_check = 1 == 1;
let lt_check = 3 < 5;
let and_expr = true && false;
let or_expr  = true || false;
let neg_int  = -42;
let neg_bool = !true;
