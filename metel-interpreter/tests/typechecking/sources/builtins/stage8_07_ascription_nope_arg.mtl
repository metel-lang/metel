// Showcase: ascription for `None` in argument position.
//
// `None` has no fields, so its type parameter cannot be inferred from the
// value itself. When passed directly as an argument, there is no binding to
// annotate, and the parameter type does not flow back into the argument.
// Ascription is the only inline option; the alternative requires a binding
// whose only purpose is to carry the type annotation to the call site.

fun first_or_default(items: i64[], fallback: Perhaps<i64>) -> i64 {
    match fallback {
        Perhaps::Some { value } => value,
        None => if (items.len() > 0) { items[0] } else { 0 },
    }
}

// Ascription form — type resolved inline, no extra name introduced.
let _: i64 = first_or_default([1, 2, 3], None : Perhaps<i64>);

// Alternative: introduce a binding to carry the type annotation.
let no_fallback: Perhaps<i64> = None;
let _: i64 = first_or_default([1, 2, 3], no_fallback);
