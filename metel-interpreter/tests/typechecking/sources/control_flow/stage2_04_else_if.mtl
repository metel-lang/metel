// Stage 2: else-if chains (statement form)
//
// The else branch of an if_expr can be another if_expr (chaining).
// Each condition must be boolean; the overall type is Unit when used as a statement.

fun check_range(x: i64) {
    if (x < 0) {
        return;
    } else if (x > 100) {
        return;
    } else {
        return;
    }
}

fun multi_branch(a: boolean, b: boolean) {
    if (a) {
    } else if (b) {
    }
}
