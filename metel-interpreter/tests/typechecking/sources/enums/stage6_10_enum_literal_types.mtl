// Stage 6: enum variant literals correctly preserve type arguments.

// Perhaps<i64> literal
let _: Perhaps<i64> = Perhaps::Some { value: 42 };

// Perhaps<Bool> literal
let _: Perhaps<Bool> = Perhaps::Some { value: true };

// Perhaps<String> literal
let _: Perhaps<String> = Perhaps::Some { value: "hello" };

// Result<i64, String> literal
let _: Result<i64, String> = Result::Ok { value: 0 };

// Result<Bool, i64> literal
let _: Result<Bool, i64> = Result::Err { error: 42 };

// Single-segment struct literals (no generics)
struct Point { x: i64, y: i64 }
let _: Point = Point { x: 1, y: 2 };
