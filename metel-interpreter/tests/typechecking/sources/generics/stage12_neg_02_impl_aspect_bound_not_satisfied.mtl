// Negative: `impl Aspect` param called with a type that does NOT implement
// the required aspect. Expect T0012.

aspect Printable {
    fun print(self);
}

struct Plain { x: Int }

// Plain does not implement Printable.

fun print_it(x: impl Printable) {
    x.print()
}

fun bad(p: Plain) {
    print_it(p) // ERROR[T0012]
}
