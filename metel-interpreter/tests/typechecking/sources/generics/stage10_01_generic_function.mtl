// Positive: generic function declarations and calls type-check correctly.

fun id<T>(x: T) -> T { x }
fun swap<A, B>(a: A, b: B) -> (B, A) { (b, a) }
fun apply<T>(f: (T) -> T, x: T) -> T { f(x) }

fun use_generics() -> i64 {
    let n: i64 = id(42);
    let s: boolean = id(true);
    let pair: (boolean, i64) = swap(1, true);
    let doubled: i64 = apply((x: i64) -> i64 { x * 2 }, 5);
    n + doubled
}
