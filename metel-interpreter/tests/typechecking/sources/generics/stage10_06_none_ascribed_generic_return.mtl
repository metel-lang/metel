// Positive: ascribed `None` in a generic function body constrains the inferred return type.

fun maybe_head<T>(items: T[]) {
    if (array_len(items) == 0) {
        return None : Perhaps<T>;
    }
    return Perhaps::Some { value: items[0] };
}

fun main() {
    let a: Perhaps<i64> = maybe_head([1, 2, 3]);
    let b: Perhaps<i64> = maybe_head([] : i64[]);
}
