// Positive: generic functions that accept function-typed parameters.

// Single type param: f maps T to T.
fun apply<T>(f: (T) -> T, x: T) -> T { f(x) }

// Two type params: f maps A to B.
fun transform<A, B>(f: (A) -> B, x: A) -> B { f(x) }

// Three-step pipeline: g(f(x)).
fun pipe<A, B, C>(f: (A) -> B, g: (B) -> C, x: A) -> C { g(f(x)) }

fun use_ho() -> i64 {
    let doubled: i64 = apply((n: i64) -> i64 { n * 2 }, 5);
    let negated: Bool = apply((b: Bool) -> Bool { !b }, false);
    let _b: Bool = negated;

    let to_bool: Bool = transform((n: i64) -> Bool { n > 0 }, 3);
    let _b2: Bool = to_bool;

    let result: i64 = pipe(
        (n: i64) -> Bool { n > 0 },
        (b: Bool) -> i64 { if (b) 1 else 0 },
        10
    );

    doubled + result
}
