// Negative: calling a bound method with an argument of the wrong type.
// serialize(self) -> String takes no args; validate(self, code: i64) takes an i64.
// Passing a String where i64 is expected should emit T0001.

aspect Validatable {
    fun validate(self, code: i64) -> Bool;
}

struct Item { value: i64 }

impl Validatable for Item {
    fun validate(self, code: i64) -> Bool { self.value == code }
}

fun bad<T: Validatable>(x: T) -> Bool {
    x.validate("not an int") // ERROR[T0001]
}
