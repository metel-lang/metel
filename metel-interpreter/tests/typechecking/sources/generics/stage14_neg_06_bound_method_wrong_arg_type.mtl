// Negative: calling a bound method with an argument of the wrong type.
// serialize(self) -> String takes no args; validate(self, code: Int) takes an Int.
// Passing a String where Int is expected should emit T0001.

aspect Validatable {
    fun validate(self, code: Int) -> Bool;
}

struct Item { value: Int }

impl Validatable for Item {
    fun validate(self, code: Int) -> Bool { self.value == code }
}

fun bad<T: Validatable>(x: T) -> Bool {
    x.validate("not an int") // ERROR[T0001]
}
