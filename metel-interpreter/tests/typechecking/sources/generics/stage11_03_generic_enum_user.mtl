// Positive: user-defined generic enum with one type parameter.

enum Maybe<T> {
    Some { value: T },
    None {},
}

fun wrap_int(n: i64) -> Maybe<i64> {
    Maybe::Some { value: n }
}

fun wrap_bool(b: Bool) -> Maybe<Bool> {
    Maybe::Some { value: b }
}

fun unwrap_or(m: Maybe<i64>, default: i64) -> i64 {
    match m {
        Maybe::Some { value } => value,
        _                     => default,
    }
}

fun use_none() -> Maybe<i64> {
    Maybe::None
}
