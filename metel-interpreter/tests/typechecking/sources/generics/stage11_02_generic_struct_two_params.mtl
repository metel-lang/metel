// Positive: generic struct with two type parameters.

struct Pair<A, B> {
    first: A,
    second: B,
}

fun make_pair(a: i64, b: Bool) -> Pair<i64, Bool> {
    Pair { first: a, second: b }
}

fun get_first(p: Pair<i64, Bool>) -> i64 {
    p.first
}

fun get_second(p: Pair<i64, Bool>) -> Bool {
    p.second
}
