// Tests that &mut self methods called on a nested struct field mutate the
// original field in place (METEL-112).

struct Counter {
    value: i64,
    step:  i64,
}

impl Counter {
    fun new(step: i64) -> Counter {
        Counter { value: 0, step: step }
    }

    fun tick(&mut self) {
        self.value += self.step;
    }

    fun get(&self) -> i64 {
        self.value
    }

    fun is_positive(&self) -> boolean {
        self.value > 0
    }

    fun reset(&mut self) {
        self.value = 0;
    }
}

struct Pair {
    a: Counter,
    b: Counter,
}

struct Nested {
    outer: Pair,
}

// ── Basic nested field mutation ───────────────────────────────────────────────

fun test_nested_field_mut() {
    let mut pair = Pair { a: Counter::new(1), b: Counter::new(10) };
    pair.a.tick();
    pair.b.tick();
    pair.b.tick();
    assert(pair.a.get() == 1);
    assert(pair.b.get() == 20);
}

// ── Multiple mutations accumulate ─────────────────────────────────────────────

fun test_nested_mut_accumulates() {
    let mut pair = Pair { a: Counter::new(3), b: Counter::new(0) };
    pair.a.tick();  // 3
    pair.a.tick();  // 6
    pair.a.tick();  // 9
    assert(pair.a.get() == 9);
    pair.a.reset();
    assert(pair.a.get() == 0);
}

// ── &self on nested field is unaffected ──────────────────────────────────────

fun test_nested_ref_reads() {
    let mut pair = Pair { a: Counter::new(5), b: Counter::new(0) };
    pair.a.tick();
    assert(pair.a.get() == 5);
    assert(pair.a.is_positive() == true);
    // repeated &self calls don't consume
    assert(pair.a.get() == 5);
}

// ── Two independent nested fields ────────────────────────────────────────────

fun test_two_independent_fields() {
    let mut pair = Pair { a: Counter::new(1), b: Counter::new(2) };
    pair.a.tick();
    pair.b.tick();
    pair.b.tick();
    assert(pair.a.get() == 1);
    assert(pair.b.get() == 4);
}

// ── Double nesting ───────────────────────────────────────────────────────────

fun test_double_nested_field_mut() {
    let mut n = Nested {
        outer: Pair { a: Counter::new(7), b: Counter::new(0) }
    };
    n.outer.a.tick();
    n.outer.a.tick();
    assert(n.outer.a.get() == 14);
}

fun main() {
    test_nested_field_mut();
    test_nested_mut_accumulates();
    test_nested_ref_reads();
    test_two_independent_fields();
    test_double_nested_field_mut();
}
