struct Point { x: i64, y: i64 }

impl Point {
    fun magnitude_sq(self) -> i64 {
        self.x * self.x + self.y * self.y
    }
    fun translate(self, dx: i64, dy: i64) -> Point {
        Point { x: self.x + dx, y: self.y + dy }
    }
}

fun main() {
    // Zero-arg (besides self) method.
    let p = Point { x: 3, y: 4 };
    let ms = p.magnitude_sq();
    assert(ms == 25);
    // Method with additional arguments that returns a new struct.
    let q = p.translate(1, 2);
    assert(q.x == 4);
    assert(q.y == 6);
}
