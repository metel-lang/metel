// Parity test for METEL-121: generic function bodies that previously used the
// untyped evaluator path now go through construction-at-call-time.
// Exercises multiple generic patterns that both pipelines must handle identically.

fun identity<T>(x: T) -> T { x }

fun first<A, B>(a: A, _b: B) -> A { a }

fun swap_apply<T, U>(x: T, f: (T) -> U) -> U { f(x) }

fun add_all<T>(a: T, b: T, c: T, combine: (T, T) -> T) -> T {
    combine(combine(a, b), c)
}

fun main() {
    // identity through various types
    assert(identity(42) == 42);
    assert(identity(true) == true);
    assert(identity("hello") == "hello");

    // first/second selection
    assert(first(1, 2) == 1);
    assert(first("a", 99) == "a");

    // higher-order generic with i64
    let doubled = swap_apply(5, (x: i64) -> i64 { x * 2 });
    assert(doubled == 10);

    let negated = swap_apply(7, (x: i64) -> i64 { x * -1 });
    assert(negated == -7);

    // multi-arg generic
    let sum = add_all(1, 2, 3, (a: i64, b: i64) -> i64 { a + b });
    assert(sum == 6);
}
