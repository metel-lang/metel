// Generic higher-order functions: passing and returning functions with type parameters.

// apply: T mapped to itself via f.
fun apply<T>(f: (T) -> T, x: T) -> T { f(x) }

// transform: A mapped to B.
fun transform<A, B>(f: (A) -> B, x: A) -> B { f(x) }

// pipe: two-step composition A→B→C.
fun pipe<A, B, C>(f: (A) -> B, g: (B) -> C, x: A) -> C { g(f(x)) }

fun main() {
    // apply at i64.
    let r1 = apply((n: i64) -> i64 { n * 2 }, 5);
    assert(r1 == 10);

    // apply at boolean.
    let r2 = apply((b: boolean) -> boolean { !b }, false);
    assert(r2);

    // apply at String (identity).
    let r3 = apply((s: String) -> String { s }, "hello");
    assert(r3 == "hello");

    // Nested apply: apply applied to result of apply.
    let r4 = apply((n: i64) -> i64 { n + 1 }, apply((n: i64) -> i64 { n * 3 }, 4));
    assert(r4 == 13);

    // transform: i64 → boolean.
    let r5 = transform((n: i64) -> boolean { n > 0 }, 3);
    assert(r5);

    let r6 = transform((n: i64) -> boolean { n > 0 }, 0);
    assert(!r6);

    // transform: boolean → i64.
    let r7 = transform((b: boolean) -> i64 { if (b) 1 else 0 }, true);
    assert(r7 == 1);

    // pipe: i64 → boolean → i64.
    let r8 = pipe(
        (n: i64) -> boolean { n > 0 },
        (b: boolean) -> i64 { if (b) 10 else -1 },
        5
    );
    assert(r8 == 10);

    // pipe: i64 → i64 → i64 (two arithmetic steps).
    let r9 = pipe(
        (n: i64) -> i64 { n * 2 },
        (n: i64) -> i64 { n + 1 },
        7
    );
    assert(r9 == 15);
}
