// User-defined Iterable via aspect — for-in dispatches through next().

aspect Iterable {
    fun next(self) -> Perhaps<i64>;
}

struct Counter {
    current: i64,
    limit:   i64,
}

impl Counter {
    fun new(limit: i64) -> Counter {
        return Counter { current: 0, limit: limit };
    }
}

impl Iterable<i64> for Counter {
    fun next(&mut self) -> Perhaps<i64> {
        if (self.current < self.limit) {
            let val = self.current;
            self.current = self.current + 1;
            return Perhaps::Some { value: val };
        }
        return None;
    }
}

fun main() {
    let mut sum = 0;
    let c = Counter::new(5);
    for (let x in c) {
        sum += x;
    }
    assert(sum == 10); // 0+1+2+3+4
}
