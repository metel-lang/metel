// A default method that calls another default method on self.

struct Measurement {
    raw: i64,
}

aspect Ops {
    fun raw(self) -> i64;

    fun scaled(self) -> i64 {
        return self.raw() * 10;
    }

    fun summary(self) -> String {
        return "raw=" + self.raw().to_string() + " scaled=" + self.scaled().to_string();
    }
}

impl Ops for Measurement {
    fun raw(self) -> i64 {
        return self.raw;
    }
}

fun main() {
    let m = Measurement { raw: 7 };
    assert(m.raw() == 7);
    assert(m.scaled() == 70);
    assert(m.summary() == "raw=7 scaled=70");
}
