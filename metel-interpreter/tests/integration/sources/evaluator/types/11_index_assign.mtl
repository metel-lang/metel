// Regression (METEL-106): computed index expressions in assignment targets must work.

fun main() {
    struct S { data: i64[] }

    // Computed index assignment.
    let mut arr = [10, 20, 30, 40, 50];
    let i = 1;
    arr[(i + 1) as u64] = 99;
    assert(arr[2] == 99);

    // Compound assignment with computed index.
    arr[(i + 1) as u64] += 1;
    assert(arr[2] == 100);

    arr[(i + 1) as u64] -= 10;
    assert(arr[2] == 90);

    arr[(i * 2) as u64] *= 2;
    assert(arr[2] == 180);

    // Simple variable index.
    let j = 0;
    arr[j as u64] = 7;
    assert(arr[0] == 7);

    // Field chain then computed index assignment.
    let mut s = S { data: [1, 2, 3] };
    s.data[i as u64] = 42;
    assert(s.data[1] == 42);
    s.data[(i + 1) as u64] = 55;
    assert(s.data[2] == 55);
}
