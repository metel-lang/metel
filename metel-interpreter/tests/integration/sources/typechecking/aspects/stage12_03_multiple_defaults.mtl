// Positive: multiple default methods can all be inherited by a single impl.

struct Value {
    n: i64,
}

aspect Ops {
    fun get(self) -> i64;

    fun doubled(self) -> i64 {
        return self.get() * 2;
    }

    fun tripled(self) -> i64 {
        return self.get() * 3;
    }
}

impl Ops for Value {
    fun get(self) -> i64 {
        return self.n;
    }
}

fun main() {
    let v = Value { n: 4 };
    let _: i64 = v.doubled();
    let _: i64 = v.tripled();
}
