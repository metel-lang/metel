// Positive: an impl may provide a method that has a default body in the aspect.

struct Circle {
    radius: i64,
}

aspect Shape {
    fun area_estimate(self) -> i64;

    fun describe(self) -> String {
        return "shape";
    }
}

impl Shape for Circle {
    fun area_estimate(self) -> i64 {
        return self.radius * self.radius;
    }

    fun describe(self) -> String {
        return "circle(r=" + self.radius.to_string() + ")";
    }
}

fun main() {
    let c = Circle { radius: 5 };
    let _: i64 = c.area_estimate();
    let _: String = c.describe();
}
