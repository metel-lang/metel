// Negative: calling a method on a bounded type param that is NOT declared
// by any of its bounds. Expect T0003.

aspect Printable {
    fun print(self);
}

struct Item { name: String }

impl Printable for Item { fun print(self) {} }

fun bad<T: Printable>(x: T) {
    x.nonexistent_method() // ERROR[T0003]
}
