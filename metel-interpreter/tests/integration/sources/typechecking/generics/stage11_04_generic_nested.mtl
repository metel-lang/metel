// Positive: nested generic types — Box<Pair<i64, boolean>>.

struct Box<T> {
    value: T,
}

struct Pair<A, B> {
    first: A,
    second: B,
}

fun make_boxed_pair(a: i64, b: boolean) -> Box<Pair<i64, boolean>> {
    Box { value: Pair { first: a, second: b } }
}

fun get_pair(b: Box<Pair<i64, boolean>>) -> Pair<i64, boolean> {
    b.value
}
