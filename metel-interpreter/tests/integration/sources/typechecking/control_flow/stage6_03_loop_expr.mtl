// Stage 6: loop expressions with break.

// Infinite loop — type is Never (diverges)
fun diverge() -> i64 {
    loop {
        // no break
    }
}

// Loop with break value
let x: i64 = loop {
    break 42;
};

// Loop with break that produces a string
let s: String = loop {
    break "done";
};

// Loop with conditional break
let mut i: i64  = 0;
let result: i64 = loop {
    i += 1;
    if (i == 5) {
        break i;
    }
};

// while loop still works
let mut n: i64  = 0;
while (n < 10) {
    n += 1;
    if (n == 5) {
        continue;
    }
}
