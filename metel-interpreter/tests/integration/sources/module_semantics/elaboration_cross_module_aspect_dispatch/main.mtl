import geometry::*;

// Regression: aspect method calls on types whose aspect is declared in another module.
// The elaborator resolves dispatch using the declaring module's SymbolId so that
// two aspects with the same name from different modules are kept distinct.

fun main() {
    let c = Circle { radius: 5 };
    let r = Rectangle { width: 3, height: 4 };

    // Aspect method dispatch on Circle
    assert(c.describe() == "Circle(r=5)");
    assert(c.scale(2) == 10);

    // Aspect method dispatch on Rectangle — same method name, different receiver type
    assert(r.describe() == "Rect(3x4)");
    assert(r.scale(3) == 36);

    // Second instance
    let c2 = Circle { radius: 10 };
    assert(c2.describe() == "Circle(r=10)");
    assert(c2.scale(5) == 50);
}
