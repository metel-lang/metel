// 09 — Casting and generics
// Covers: as (i64->f64, f64->i64 truncation), generic structs,
//         generic functions with multiple type params, where clauses,
//         inline aspectbounds.

aspectDisplay {
    fun display(self) -> String;
}

struct Box<T> {
    value: T,
}

impl Box<i64> {
    fun new(v: i64) -> Box<i64> {
        return Box { value: v };
    }
}

impl Box<String> {
    fun new(v: String) -> Box<String> {
        return Box { value: v };
    }
}

impl Display for Box<i64> {
    fun display(self) -> String {
        return "Box(" + int_to_string(self.value) + ")";
    }
}

impl Display for Box<String> {
    fun display(self) -> String {
        return "Box(" + self.value + ")";
    }
}

struct Pair<A, B> {
    first: A,
    second: B,
}

impl Pair<i64, f64> {
    fun new(a: i64, b: f64) -> Pair<i64, f64> {
        return Pair { first: a, second: b };
    }

    // cast first to f64 for arithmetic
    fun sum_as_float(self) -> f64 {
        let a_float: f64 = self.first as f64;
        return a_float + self.second;
    }
}

fun show<T: Display>(item: T) {
    println(item.display());
}

fun swap<A, B>(p: Pair<A, B>) -> Pair<B, A> {
    return Pair { first: p.second, second: p.first };
}

fun clamp(value: f64, lo: f64, hi: f64) -> f64 {
    if (value < lo) { return lo; }
    if (value > hi) { return hi; }
    return value;
}

fun main() {
    // --- i64 -> f64 cast ---
    let i = 7;
    let f: f64 = i as f64;
    println(float_to_string(f));          // 7.0

    // --- f64 -> i64 cast (truncates toward zero) ---
    let pi: f64 = 3.99;
    let truncated: i64 = pi as i64;
    println(int_to_string(truncated));    // 3

    let neg: f64 = -2.7;
    let neg_int: i64 = neg as i64;
    println(int_to_string(neg_int));      // -2  (truncates toward zero)

    // --- as used in arithmetic ---
    let count = 3;
    let total: f64 = 10.0;
    let avg = total / (count as f64);
    println(float_to_string(avg));        // 3.3333...

    // --- generic Box ---
    let bi = Box::new(42);
    let bs = Box::new("hello");
    show(bi);    // Box(42)
    show(bs);    // Box(hello)

    // --- Pair with cast in method ---
    let p = Pair::new(3, 1.5);
    println(float_to_string(p.sum_as_float()));   // 4.5

    // --- swap generic pair (Pair<String, i64>) ---
    let sp: Pair<String, i64> = Pair { first: "world", second: 99 };
    let swapped = swap(sp);
    println(int_to_string(swapped.first));   // 99
    println(swapped.second);                 // world

    // --- clamp ---
    println(float_to_string(clamp(5.0, 0.0, 10.0)));   // 5.0
    println(float_to_string(clamp(-3.0, 0.0, 10.0)));  // 0.0
    println(float_to_string(clamp(15.0, 0.0, 10.0)));  // 10.0
}
