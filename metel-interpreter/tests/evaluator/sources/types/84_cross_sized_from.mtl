// Cross-sized numeric From casts: every numeric type can be cast to every other.

fun main() {
    // ── Integer → smaller integer (truncating) ────────────────────────────────
    let i32_to_i8:  i8  = 200i32 as i8;
    assert(i32_to_i8 == -56i8);           // 200 mod 256 = 200 → two's comp = -56

    let i16_to_i8:  i8  = 127i16 as i8;
    assert(i16_to_i8 == 127i8);

    let u16_to_u8:  u8  = 300u16 as u8;
    assert(u16_to_u8 == 44u8);            // 300 mod 256 = 44

    let u32_to_i16: i16 = 40000u32 as i16;
    assert(u32_to_i16 == -25536i16);      // 40000 mod 65536 = 40000 → two's comp = -25536

    // ── Integer → wider integer (zero/sign extension) ─────────────────────────
    let i8_to_i32:  i32 = 42i8  as i32;
    assert(i8_to_i32 == 42i32);

    let i8_to_i64:  i64 = 42i8  as i64;
    assert(i8_to_i64 == 42);

    let u8_to_u32:  u32 = 200u8  as u32;
    assert(u8_to_u32 == 200u32);

    let i16_to_i32: i32 = 1000i16 as i32;
    assert(i16_to_i32 == 1000i32);

    let i32_to_i64: i64 = 100000i32 as i64;
    assert(i32_to_i64 == 100000);

    let u32_to_u64: u64 = 999u32 as u64;
    assert(u32_to_u64 == 999u64);

    // ── Signed → unsigned (same width, wrapping) ─────────────────────────────
    let i8_to_u8:   u8  = -1i8  as u8;    // -1i8 → 255u8
    assert(i8_to_u8 == 255u8);

    let i16_to_u16: u16 = -1i16 as u16;   // -1i16 → 65535u16
    assert(i16_to_u16 == 65535u16);

    // ── Integer → float ───────────────────────────────────────────────────────
    let i8_to_f32:  f32 = 42i8  as f32;
    assert(i8_to_f32 == 42.0f32);

    let i16_to_f32: f32 = 1000i16 as f32;
    assert(i16_to_f32 == 1000.0f32);

    let u32_to_f64: f64 = 999u32 as f64;
    assert(u32_to_f64 == 999.0);

    let i32_to_f32: f32 = 100i32 as f32;
    assert(i32_to_f32 == 100.0f32);

    // ── Float → float ─────────────────────────────────────────────────────────
    let f32_to_f64: f64 = 1.5f32 as f64;
    assert(f32_to_f64 == 1.5);

    let f64_to_f32: f32 = 3.14 as f32;
    assert(f64_to_f32 == 3.14f32);

    // ── Float → integer (truncating) ─────────────────────────────────────────
    let f32_to_i32: i32 = 7.9f32 as i32;
    assert(f32_to_i32 == 7i32);

    let f32_to_u8:  u8  = 200.6f32 as u8;
    assert(f32_to_u8 == 200u8);
}
