// Float → integer try-cast: whole numbers in range succeed, fractional or
// out-of-range values return None.

fun main() {
    // ── Whole float in range → Some ───────────────────────────────────────────
    let r1 = 3.0 as? i8;
    match r1 {
        Perhaps::Some { value } => assert(value == 3i8),
        Perhaps::None => assert(false),
    }

    let r2 = 100.0 as? i32;
    match r2 {
        Perhaps::Some { value } => assert(value == 100i32),
        Perhaps::None => assert(false),
    }

    let r3 = 0.0 as? i64;
    match r3 {
        Perhaps::Some { value } => assert(value == 0),
        Perhaps::None => assert(false),
    }

    let r4 = 255.0 as? u8;
    match r4 {
        Perhaps::Some { value } => assert(value == 255u8),
        Perhaps::None => assert(false),
    }

    let r5 = -42.0 as? i16;
    match r5 {
        Perhaps::Some { value } => assert(value == -42i16),
        Perhaps::None => assert(false),
    }

    // ── Fractional float → None ───────────────────────────────────────────────
    let r6 = 3.14 as? i8;
    match r6 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    let r7 = 1.5 as? i32;
    match r7 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    // ── Out-of-range whole float → None ──────────────────────────────────────
    let r8 = 200.0 as? i8;
    match r8 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    let r9 = -1.0 as? u8;
    match r9 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    // ── f32 source: whole → Some, fractional → None ──────────────────────────
    let r10 = 7.0f32 as? i8;
    match r10 {
        Perhaps::Some { value } => assert(value == 7i8),
        Perhaps::None => assert(false),
    }

    let r11 = 2.5f32 as? i16;
    match r11 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }
}
