fun main() {
    // Fits: i64 in i8 range → Some.
    let fits: i64 = 42;
    let r1 = fits as? i8;
    match r1 {
        Perhaps::Some { value } => assert(value == 42i8),
        Perhaps::None => assert(false),
    }

    // Does not fit: 200 is out of i8 range → None.
    let too_big: i64 = 200;
    let r2 = too_big as? i8;
    match r2 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    // Negative overflow → None.
    let neg: i64 = -200;
    let r3 = neg as? i8;
    match r3 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    // Boundary: exactly i8::MAX (127) → Some.
    let max: i64 = 127;
    let r4 = max as? i8;
    match r4 {
        Perhaps::Some { value } => assert(value == 127i8),
        Perhaps::None => assert(false),
    }

    // Boundary: 128 is just outside i8 range → None.
    let over: i64 = 128;
    let r5 = over as? i8;
    match r5 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    // u8: fits.
    let byte: i64 = 255;
    let r6 = byte as? u8;
    match r6 {
        Perhaps::Some { value } => assert(value == 255u8),
        Perhaps::None => assert(false),
    }

    // u8: negative → None.
    let neg2: i64 = -1;
    let r7 = neg2 as? u8;
    match r7 {
        Perhaps::Some { value } => assert(false),
        Perhaps::None => assert(true),
    }

    // i32: fits.
    let mid: i64 = 100000;
    let r8 = mid as? i32;
    match r8 {
        Perhaps::Some { value } => assert(value == 100000i32),
        Perhaps::None => assert(false),
    }
}
