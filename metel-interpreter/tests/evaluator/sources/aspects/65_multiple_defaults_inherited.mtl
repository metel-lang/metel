// An aspect with multiple default methods; the impl provides only the required
// method and inherits all defaults.

struct Counter {
    count: i64,
}

aspect Stats {
    fun value(self) -> i64;

    fun doubled(self) -> i64 {
        return self.value() * 2;
    }

    fun tripled(self) -> i64 {
        return self.value() * 3;
    }
}

impl Stats for Counter {
    fun value(self) -> i64 {
        return self.count;
    }
}

fun main() {
    let c = Counter { count: 5 };
    assert(c.value() == 5);
    assert(c.doubled() == 10);
    assert(c.tripled() == 15);

    let zero = Counter { count: 0 };
    assert(zero.doubled() == 0);
    assert(zero.tripled() == 0);
}
