struct Person {
    name: String,
}

aspect Greet {
    fun name(self) -> String;

    fun greet(self) -> String {
        return "Hello, " + self.name();
    }
}

impl Greet for Person {
    fun name(self) -> String {
        return self.name;
    }
}

fun main() {
    let p = Person { name: "Ada" };
    assert(p.greet() == "Hello, Ada");
}
