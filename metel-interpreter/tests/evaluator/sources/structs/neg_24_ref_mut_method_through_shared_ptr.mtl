// TYPECHECK_ERROR[T0006]
// Calling a &mut self method through a *T (immutable) pointer is rejected.

struct Counter {
    value: Int,
}

impl Counter {
    fun increment(&mut self) {
        self.value += 1;
    }
}

fun main() {
    let mut c = Counter { value: 0 };
    let p: *Counter = &c;
    p.increment();
}
