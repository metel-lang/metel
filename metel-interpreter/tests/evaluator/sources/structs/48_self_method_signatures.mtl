struct Point { x: i64 }

impl Point {
    fun clone(self) -> Self {
        self
    }

    fun same_as(self, other: Self) -> Bool {
        self.x == other.x
    }
}

enum Token {
    i64 { value: i64 },
}

impl Token {
    fun identity(self) -> Self {
        self
    }
}

fun main() {
    let p = Point { x: 3 };
    let q = p.clone();
    assert(q.x == 3);
    assert(p.same_as(q));

    let token = Token::i64 { value: 9 };
    let token_copy = token.identity();
    match token_copy {
        Token::i64 { value } => assert(value == 9),
    }
}
