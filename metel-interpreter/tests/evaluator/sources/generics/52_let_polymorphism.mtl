// Let-bound closures without annotations are generalized into polymorphic schemes.

let id = (x) -> { x };
let swap_vals = (a) -> { (b) -> { (b, a) } };

fun main() {
    // id used at i64, Bool, String.
    assert(id(42) == 42);
    assert(id(true));
    assert(id("hello") == "hello");

    // id in arithmetic context.
    assert(id(10) + id(20) == 30);

    // Nested id calls.
    assert(id(id(99)) == 99);

    // Two independent let-poly closures.
    let double = (n: i64) -> i64 { n * 2 };
    let negate = (b: Bool) -> Bool { !b };
    assert(double(5) == 10);
    assert(negate(false));
}
