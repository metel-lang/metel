enum Maybe<T> {
    Some { value: T },
    None {},
}

fun unwrap_or_int(m: Maybe<i64>, default: i64) -> i64 {
    match m {
        Maybe::Some { value } => value,
        _                     => default,
    }
}

fun unwrap_or_bool(m: Maybe<boolean>, default: boolean) -> boolean {
    match m {
        Maybe::Some { value } => value,
        _                     => default,
    }
}

fun main() {
    let some_int = Maybe::Some { value: 42 };
    assert(unwrap_or_int(some_int, 0) == 42);

    let none_int: Maybe<i64> = Maybe::None;
    assert(unwrap_or_int(none_int, 99) == 99);

    let some_bool = Maybe::Some { value: true };
    assert(unwrap_or_bool(some_bool, false));

    let none_bool: Maybe<boolean> = Maybe::None;
    assert(!unwrap_or_bool(none_bool, false));
}
