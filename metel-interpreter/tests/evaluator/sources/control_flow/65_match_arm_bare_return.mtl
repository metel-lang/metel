// Bare `return` and `break` in match arm bodies (no surrounding braces).
// Previously rejected by the grammar; fixed in #226.

fun classify(n: Int) -> String {
    match n {
        0 => return "zero",
        _ => return "nonzero",
    }
}

fun sign(n: Int) -> Int {
    match n {
        0 => return 0,
        _ => if (n > 0) { return 1; } else { return -1; },
    }
}

fun first_err(xs: Int[]) -> Perhaps<Int> {
    let a = match xs[0] {
        0 => return None,
        n => n,
    };
    Perhaps::Some { value: a }
}

fun find_nonzero(arr: Int[]) -> Int {
    let mut i = 0;
    loop {
        if (i >= array_len(arr)) { break -1; }
        let found = match arr[i] {
            0 => { i = i + 1; continue; },
            n => break n,
        };
        found
    }
}

fun main() {
    assert(classify(0) == "zero");
    assert(classify(5) == "nonzero");
    assert(classify(-3) == "nonzero");

    assert(sign(0) == 0);
    assert(sign(7) == 1);
    assert(sign(-2) == -1);

    let vals = [3, 1, 2];
    match first_err(vals) {
        Perhaps::Some { value } => assert(value == 3),
        None => assert(false),
    };

    let zeros = [0, 1, 2];
    match first_err(zeros) {
        Perhaps::Some { value } => assert(false),
        None => assert(true),
    };

    // break in a match arm body
    assert(find_nonzero([0, 0, 7]) == 7);
    assert(find_nonzero([5, 0, 0]) == 5);
    assert(find_nonzero([0, 0, 0]) == -1);
}
