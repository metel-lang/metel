// Mutual recursion.
fun is_even(n: i64) -> boolean {
    if (n == 0) { true } else { is_odd(n - 1) }
}
fun is_odd(n: i64) -> boolean {
    if (n == 0) { false } else { is_even(n - 1) }
}
// Early return via return statement (not tail expression).
fun sign(n: i64) -> i64 {
    if (n > 0) { return 1; }
    if (n < 0) { return -1; }
    return 0;
}
// Function that calls a builtin.
fun greet(name: String) -> String {
    string_concat("hello ", name)
}
// Function stored in a variable and called through it.
fun double(x: i64) -> i64 { x * 2 }

fun main() {
    // Mutual recursion.
    assert(is_even(4));
    assert(is_odd(3));
    assert(is_even(0));
    assert(is_odd(1));
    // Early return.
    assert(sign(5)  ==  1);
    assert(sign(-3) == -1);
    assert(sign(0)  ==  0);
    // Calling a builtin from a user function.
    let s = greet("world");
    assert(s == "hello world");
    // Call through a variable binding.
    let f = double;
    let r = f(21);
    assert(r == 42);
}
