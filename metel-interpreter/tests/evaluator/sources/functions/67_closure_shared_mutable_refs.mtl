fun get_closures() {
    let mut shared = 0;
    let mut ptr = &mut shared; 
    let first_closure = () -> {
        *ptr += 1;
    };

    let second_closure = () -> {
        *ptr += 2;
    };

    let third_closure = () -> {
        return *ptr;
    };

    return (first_closure, second_closure, third_closure);
}

fun main() {
    
    let closures = get_closures();
    
    let first_closure = closures.0;
    let second_closure = closures.1;
    let third_closure = closures.2;

    first_closure();
    first_closure();
    second_closure();
    assert(third_closure() == 4);

}