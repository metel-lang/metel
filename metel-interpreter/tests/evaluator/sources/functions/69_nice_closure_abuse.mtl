// Creates a tuple of three closures that all operate on the same mutable pointer
// Returns: (increment_by_1, increment_by_2, get_current_value)
fun get_closures(ptr: *mut Int) {
    
    // First closure: increments the value at ptr by 1
    let first_closure = () -> {
        *ptr += 1;  // Dereference ptr and add 1 to the value it points to
    };

    // Second closure: increments the value at ptr by 2
    let second_closure = () -> {
        *ptr += 2;  // Dereference ptr and add 2 to the value it points to
    };

    // Third closure: reads and returns the current value at ptr
    let third_closure = () -> {
        return *ptr;  // Dereference ptr and return the current value
    };

    // Return all three closures as a tuple
    // Each closure captures the same ptr, so they all operate on the same shared value
    return (first_closure, second_closure, third_closure);
}

// Creates two independent sets of closures, each operating on the same shared value
// Both closure sets point to the same memory location via ptr
// Returns: ((set1_closure1, set1_closure2, set1_closure3), (set2_closure1, set2_closure2, set2_closure3))
fun get_closure_sets(ptr: *mut Int) {

    // Note: shared_value is declared but not used (leftover from refactoring?)
    let mut shared_value = 0;
    
    // Create the first set of three closures, all capturing ptr
    let first_closure_set = get_closures(ptr);

    // Create the second set of three closures, also capturing the same ptr
    // Both sets will operate on the same underlying value
    let second_closure_set = get_closures(ptr);
    
    // Return both closure sets as a nested tuple
    (first_closure_set, second_closure_set)
}

fun apply_functions(funs : Array<*() -> ()>) {
    for(let fn in funs){
        fn();
    }
}


fun main() {
    
    // Initialize a mutable integer that will be shared across all closures
    let mut shared_value = 1;
    
    // Get two closure sets; both sets operate on the same shared_value
    // Structure: closure_sets.0 = first_closure_set, closure_sets.1 = second_closure_set
    let closure_sets = get_closure_sets(&mut shared_value);

    apply_functions([&closure_sets.1.0, &closure_sets.0.1]);

    // Verify that both closure sets see the same updated value (4)
    // The third closure from each set returns the current value of shared_value
    // Both should return 4 since they all reference the same memory location
    assert(closure_sets.0.2() == shared_value && closure_sets.1.2() == shared_value);
}
